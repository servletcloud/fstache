<li class="list-none my-1 select-none">
  <div class="flex items-center gap-2.5 py-1.5 px-3 rounded-lg hover:bg-white/5 transition-colors text-sm text-text-secondary hover:text-text-primary cursor-pointer">
    {{#has_children}}
      <!-- Folder Icon -->
      <svg class="w-4 h-4 text-primary shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path>
      </svg>
    {{/has_children}}
    {{^has_children}}
      <!-- File/Document Icon -->
      <svg class="w-4 h-4 text-text-muted shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
      </svg>
    {{/has_children}}
    <span class="font-medium truncate">{{name}}</span>
  </div>

  {{#has_children}}
    <ul class="pl-4 ml-2 border-l border-card-border mt-1 flex flex-col gap-0.5">
      {{#children}}
        {{! Recursive partial invocation }}
        {{> node}}
      {{/children}}
    </ul>
  {{/has_children}}
</li>
