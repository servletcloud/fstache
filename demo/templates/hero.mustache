{{! OBJECT CONTEXT: Renders content within the scoped context of the "hero" object }}
{{#hero}}
<!-- Hero Section -->
<section class="relative text-center max-w-4xl mx-auto pt-16 pb-20">
  <div class="text-xs font-bold tracking-[0.15em] uppercase text-accent mb-6">{{site.tagline}}</div>
  <h1 class="font-display text-5xl md:text-7xl font-extrabold leading-none mb-6 tracking-tight bg-gradient-to-r from-white via-slate-100 to-slate-400 bg-clip-text text-transparent">
    <span class="bg-gradient-to-r from-primary to-secondary bg-clip-text text-transparent">fstache:</span><br>{{gradient_text}}
  </h1>
  <p class="text-lg md:text-xl text-text-secondary max-w-2xl mx-auto mb-10 font-normal">{{subheading}}</p>
  <div class="flex justify-center gap-5 mb-20">
    <a href="#pricing" class="inline-flex items-center justify-center px-8 py-3.5 rounded-xl font-semibold text-base bg-gradient-to-br from-primary to-primary-hover text-white shadow-[0_4px_20px_rgba(99,102,241,0.4)] hover:-translate-y-0.5 hover:shadow-[0_6px_24px_rgba(99,102,241,0.6)] transition-all duration-300 no-underline">{{cta_primary}}</a>
    <a href="#features" class="inline-flex items-center justify-center px-8 py-3.5 rounded-xl font-semibold text-base bg-white/5 text-text-primary border border-card-border hover:bg-white/10 hover:border-white/20 hover:-translate-y-0.5 transition-all duration-300 no-underline">{{cta_secondary}}</a>
  </div>

  <!-- Stats Grid -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 max-w-3xl mx-auto">
    {{#stats}}
      <div class="bg-card-bg border border-card-border rounded-2xl p-7 backdrop-blur-md hover:border-card-hover-border hover:-translate-y-0.5 transition-all duration-300">
        <div class="font-display text-4xl font-bold bg-gradient-to-b from-white to-text-secondary bg-clip-text text-transparent mb-1">{{value}}</div>
        <div class="text-text-muted text-[0.85rem] font-medium uppercase tracking-wider">{{label}}</div>
      </div>
    {{/stats}}
  </div>
</section>
{{/hero}}
