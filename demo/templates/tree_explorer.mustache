<!-- Recursive Partials Showcase -->
<section id="sitemap" class="py-24 border-t border-card-border">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
    <div>
      <div class="text-[0.85rem] font-bold tracking-wider uppercase text-primary mb-3">Resource Index</div>
      <h2 class="font-display text-4xl font-bold tracking-tight mb-6">Recursive Document Sitemap</h2>
      <p class="text-text-secondary mb-6 text-[0.95rem] leading-relaxed">
        F-Stache renders complex hierarchy schemas dynamically. This sitemap explorer component resolves nested data relationships recursively using self-referencing templates.
      </p>
      <p class="text-text-muted text-[0.9rem] leading-relaxed">
        Verify compliance: every leaf node resolves to its base context and terminates cleanly once the recursive children arrays resolve as falsey or empty, preventing context leakage.
      </p>
    </div>

    <!-- Document Tree Widget Box -->
    <div class="bg-card-bg border border-card-border rounded-3xl p-8 backdrop-blur-md shadow-2xl relative overflow-hidden max-w-[480px] w-full mx-auto lg:mx-0">
      <div class="flex items-center justify-between border-b border-card-border pb-4 mb-4">
        <div class="flex items-center gap-2">
          <span class="w-3 h-3 rounded-full bg-primary/40 animate-ping"></span>
          <span class="text-xs font-bold uppercase tracking-wider text-text-muted">FSTACHE INDEXER</span>
        </div>
        <span class="text-xs font-mono text-primary font-bold">docs_tree.json</span>
      </div>

      <div class="bg-black/30 border border-white/5 rounded-2xl p-5 overflow-y-auto max-h-[320px] shadow-[inset_0_2px_8px_rgba(0,0,0,0.4)]">
        <ul class="flex flex-col gap-1 pr-2">
          {{#docs_tree}}
            {{> node}}
          {{/docs_tree}}
        </ul>
      </div>
    </div>
  </div>
</section>
