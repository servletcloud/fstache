{{! LIST ITERATION: Renders release timeline dynamically }}
<!-- Changelog Section -->
<section id="changelog" class="py-24 border-t border-card-border">
  <div class="text-center max-w-2xl mx-auto mb-16">
    <div class="text-[0.85rem] font-bold tracking-wider uppercase text-primary mb-3">Version History</div>
    <h2 class="font-display text-4xl font-bold tracking-tight mb-4">F-Stache Changelog</h2>
    <p class="text-text-secondary">Track our progress, release tags, performance milestones, and specs compliance updates.</p>
  </div>

  <div class="max-w-4xl mx-auto relative before:absolute before:top-0 before:bottom-0 before:left-4 md:before:left-1/2 before:-translate-x-1/2 before:w-0.5 before:bg-card-border">
    {{#changelog}}
      <div class="relative flex flex-col md:flex-row justify-between items-start mb-16 md:odd:flex-row-reverse group">
        <!-- Circle indicator -->
        <div class="absolute left-4 md:left-1/2 -translate-x-1/2 w-6 h-6 rounded-full bg-bg-primary border-4 border-primary/40 group-hover:border-primary transition-colors duration-300 z-10"></div>

        <!-- Empty Space on other side for grid alignment on desktop -->
        <div class="hidden md:block w-[45%]"></div>

        <!-- Content Box -->
        <div class="bg-card-bg border border-card-border rounded-3xl p-8 backdrop-blur-md hover:border-card-hover-border transition-colors duration-300 w-[90%] md:w-[45%] ml-12 md:ml-0 shadow-xl">
          <div class="flex justify-between items-center mb-4">
            <span class="font-display text-xl font-bold text-text-primary">{{version}}</span>
            <span class="text-xs font-semibold text-primary uppercase tracking-wider">{{date}}</span>
          </div>

          <div class="flex flex-col gap-4">
            <div>
              <h4 class="text-xs font-bold uppercase tracking-wider text-text-muted mb-2">Additions</h4>
              <ul class="list-disc pl-5 text-sm text-text-secondary flex flex-col gap-1">
                {{#additions}}
                  <li>{{.}}</li>
                {{/additions}}
              </ul>
            </div>

            <div>
              <h4 class="text-xs font-bold uppercase tracking-wider text-text-muted mb-2">Fixes & Optimizations</h4>
              <ul class="list-disc pl-5 text-sm text-text-secondary flex flex-col gap-1">
                {{#fixes}}
                  <li>{{.}}</li>
                {{/fixes}}
              </ul>
            </div>
          </div>
        </div>
      </div>
    {{/changelog}}
  </div>
</section>
