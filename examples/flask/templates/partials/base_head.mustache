<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{title}}</title>
  <style>
    :root {
      color-scheme: light;
      font-family: Inter, ui-sans-serif, system-ui, sans-serif;
      line-height: 1.5;
      color: #172026;
      background: #f6f7f4;
    }

    body {
      margin: 0;
    }

    a {
      color: inherit;
    }

    .topbar {
      display: flex;
      justify-content: space-between;
      gap: 1rem;
      padding: 1rem max(1rem, calc((100vw - 64rem) / 2));
      background: #ffffff;
      border-bottom: 1px solid #dde4dc;
    }

    .brand {
      font-weight: 700;
    }

    .nav {
      display: flex;
      gap: 1rem;
    }

    .shell {
      max-width: 64rem;
      margin: 0 auto;
      padding: 3rem 1rem;
    }

    .intro {
      max-width: 44rem;
    }

    .kicker {
      margin: 0 0 0.5rem;
      color: #386641;
      font-weight: 700;
      text-transform: uppercase;
    }

    h1,
    h2,
    p {
      margin-top: 0;
    }

    h1 {
      margin-bottom: 1rem;
      font-size: clamp(2.25rem, 7vw, 4.5rem);
      line-height: 1;
    }

    .lead {
      font-size: 1.25rem;
    }

    .notice {
      padding: 0.75rem 1rem;
      background: #fff7d6;
      border: 1px solid #e9d982;
    }

    .safe {
      color: #4b5563;
    }

    .badge {
      display: inline-block;
      padding: 0.125rem 0.5rem;
      color: #ffffff;
      background: #386641;
      border-radius: 999px;
      font-size: 0.875rem;
    }

    .cards {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
      gap: 1rem;
      margin: 2rem 0;
    }

    .card {
      padding: 1rem;
      background: #ffffff;
      border: 1px solid #dde4dc;
      border-radius: 8px;
    }

    .card h2 {
      margin-bottom: 0.5rem;
      font-size: 1.125rem;
    }

    .features {
      padding-top: 1rem;
      border-top: 1px solid #dde4dc;
    }
  </style>
</head>
